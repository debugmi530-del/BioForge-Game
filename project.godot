; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the format may change without notice.
;
; Format:
;    [section] ; section goes between []
;    param=val ; assign values to parameters

config_version=5

[application]

config/name="BioForge"
config/description="Build creatures from bones, muscles and joints — then watch AI evolve them"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://assets/icon.svg"

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
CreatureData="*res://scripts/autoload/creature_data.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"

